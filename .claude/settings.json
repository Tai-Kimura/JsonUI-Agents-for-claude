      "Bash(./gradlew tasks *)",
      "Bash(./gradlew publishAllPublicationsToMavenCentralRepository --no-daemon)",
      "Bash(./gradlew :library-dynamic:compileReleaseKotlin --no-daemon)"
    ]
  },
  "hooks": {
